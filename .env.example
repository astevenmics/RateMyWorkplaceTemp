# Copy this file to .env on the VPS (NOT in git) and fill in real values.
# `docker compose` reads .env automatically.

# ---- Database ----
# Used by the app's JDBC connection (jdbc:mysql://db:3306/myworktea is set in
# docker-compose.yml's DBURL directly since it's fixed by the compose network,
# not something you need to set here).
DBUSER=myworktea
DBPASSWORD=change-me-to-a-long-random-password
# Only used to initialize the mariadb container itself (root password) — the
# app never uses it directly.
DB_ROOT_PASSWORD=change-me-to-a-different-long-random-password

# ---- Outbound mail (verification codes, notifications) ----
MAILHOST=smtp.your-provider.com
MAILPORT=587
MAILUSER=your-smtp-username
MAILPASSWORD=your-smtp-password
MAIL_FROM=no-reply@your-domain.com

# ---- Bootstrap admin account (created once on first startup) ----
ADMINUSERNAME=admin
ADMINPASSWORD=change-me-immediately-after-first-login
ADMINEMAIL=you@your-domain.com

# ---- Required because Caddy sits in front of the app as a reverse proxy ----
# Without this, every visitor's IP is seen by the app as Caddy's internal
# container IP, which breaks per-IP rate limiting AND the anonymous rant
# voter/poster identity (everyone would collapse into one shared "voter").
APP_RATELIMIT_TRUST_FORWARDED_FOR=true

# Cookies require HTTPS (Caddy terminates TLS in front of the app) — leave
# this at the default (true) once you've set up a real domain with Caddy.
# SESSION_COOKIE_SECURE=true
